          "target": "css=input[type=\"email\"]",
          "targets": [
            [
              "css=input[type=\"email\"]",
              "css"
            ]
          ],
          "value": "10000"
        },
        {
          "id": "60a146bb-e43b-4a25-8fbb-5132c715dd5f",
          "comment": "",
          "command": "executeScript",
          "target": "const el = document.querySelector(\"input[type=\\\"email\\\"]\"); el.value = \"carmen.vilca@gmail.com\"; el.dispatchEvent(new Event('input', { bubbles: true })); el.dispatchEvent(new Event('change', { bubbles: true }));",
          "targets": [
            [
              "const el = document.querySelector(\"input[type=\\\"email\\\"]\"); el.value = \"carmen.vilca@gmail.com\"; el.dispatchEvent(new Event('input', { bubbles: true })); el.dispatchEvent(new Event('change', { bubbles: true }));",
