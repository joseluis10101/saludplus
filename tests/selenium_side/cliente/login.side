      "name": "inicia sesión con un correo registrado y va a mis citas",
      "commands": [
        {
          "id": "f68bdb34-4f75-4c3f-a9f0-7fdeb07bc08a",
          "comment": "localStorage es por origen: hay que visitar el sitio antes de poder limpiarlo.",
