          "target": "/",
          "targets": [
            [
              "/",
              ""
            ]
          ],
          "value": ""
        },
        {
          "id": "14d051a2-9b30-47a3-82cc-6eca5cbe2e8f",
          "comment": "",
          "command": "executeScript",
          "target": "window.localStorage.clear()",
